{
  "gateway": {
    "controlUi": {
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "YOUR_AUTH_TOKEN_HERE"
    },
    "mode": "local"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "bailian": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "YOUR_BAILIAN_API_KEY_HERE",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-5",
            "name": "glm-5",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 202752,
            "maxTokens": 16384,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "compat": { "thinkingFormat": "qwen" }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bailian/glm-5"
      },
      "systemPromptOverride": "YOUR_SYSTEM_PROMPT_HERE",
      "skipBootstrap": true
    }
  },
  "tools": {
    "profile": "coding"
  },
  "channels": {
    "openclaw-weixin": {
      "enabled": true,
      "dmPolicy": "open"
    }
  },
  "plugins": {
    "entries": {
      "openclaw-weixin": {
        "enabled": true
      }
    }
  },
  "env": {
    "DB_HOST": "mysql",
    "DB_PORT": "3306",
    "DB_USER": "root",
    "DB_PASSWORD": "root",
    "DB_NAME": "passion_fruit"
  }
}